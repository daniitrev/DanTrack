// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    userId         String    @id @default(uuid())
    email          String    @unique
    name           String?   @db.VarChar(255)
    password       String
    role           Role      @default(MEMBER)
    lastSeenAt     DateTime  @default(now())
    createdAt      DateTime  @default(now())
    tasks          Task[]
    projects       Project[]
    memberProjects MemberProject[]
    timeEntries    TimeEntry[]
}

enum Role {
    MEMBER
    MANAGER
    ADMIN
}

model Project {
    projectId      String     @id @default(uuid())
    title          String     @db.VarChar(255)
    description    String?    @db.Text
    createdAt      DateTime   @default(now())
    updatedAt      DateTime   @updatedAt
    owner          User       @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
    ownerId        String
    @@index([ownerId])
    memberProjects MemberProject[]
    tasks          Task[]
}

model MemberProject {
    member      User     @relation(fields: [memberId], references: [userId], onDelete: Cascade)
    memberId    String
    project     Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
    projectId   String
    assignedAt  DateTime @default(now())
    @@id([memberId, projectId])
}

model Task {
    taskId       String   @id @default(uuid())
    title        String   @db.VarChar(255)
    description  String?  @db.Text
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    status       Status   @default(TODO)
    project      Project  @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
    projectId    String
    creator      User     @relation(fields: [creatorId], references: [userId], onDelete: Cascade)
    creatorId    String
    @@index([creatorId])
    timeEntry    TimeEntry[]
}

enum Status {
    TODO
    IN_PROGRESS
    DONE
}

model TimeEntry {
    timeEntryId String    @id @default(uuid())
    startTime   DateTime  @default(now())
    endTime     DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    worker    User      @relation(fields: [workerId], references: [userId], onDelete: Cascade)
    workerId  String
    task     Task      @relation(fields: [taskId], references: [taskId], onDelete: Cascade)
    taskId   String
    @@index([startTime, endTime])
}
