// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId     String   @id @default(uuid())
  email      String   @unique
  name       String?  @db.VarChar(255)
  password   String
  role       Role     @default(MEMBER)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  refreshTokens  RefreshToken[]
  createdTasks   Task[]          @relation("TaskCreator")
  createdProject Project[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  memberProjects MemberProject[]
  timeEntries    TimeEntry[]
}

model RefreshToken {
  id          String   @id @unique @default(uuid())
  hashedToken String   @unique
  userId      String
  User        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expireAt    DateTime
}

enum ProjectRole {
  MEMBER
  EDITOR
  OWNER
}

enum Role {
  MEMBER
  MANAGER
  ADMIN
}

model Project {
  projectId   String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  status      Status   @default(NOT_STARTED)
  
  owner          User            @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  memberProjects MemberProject[]
  tasks          Task[]

  @@index([ownerId])
}

model MemberProject {
  memberId    String
  projectRole ProjectRole @default(MEMBER)
  projectId   String
  assignedAt  DateTime    @default(now())

  member  User    @relation(fields: [memberId], references: [userId], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@id([memberId, projectId])
}

model Task {
  taskId      String   @id @default(uuid())
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      Status   @default(NOT_STARTED)
  priority    Priority @default(ABSENT)
  deadline    DateTime @default(now())
  assigneeId  String?
  projectId   String?
  creatorId   String

  assignee  User?       @relation("TaskAssignee", fields: [assigneeId], references: [userId], onDelete: SetNull)
  project   Project?    @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  creator   User        @relation("TaskCreator", fields: [creatorId], references: [userId], onDelete: Cascade)
  timeEntry TimeEntry[]

  @@index([assigneeId])
  @@index([projectId])
  @@index([creatorId])
}

enum Status {
  TODO
  NOT_STARTED
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  ABSENT
  LOW
  HIGH
  CRITICAL
}

model TimeEntry {
  timeEntryId String    @id @default(uuid())
  startTime   DateTime  @default(now())
  endTime     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workerId    String
  taskId      String

  worker User @relation(fields: [workerId], references: [userId], onDelete: Cascade)
  task   Task @relation(fields: [taskId], references: [taskId], onDelete: Cascade)

  @@index([startTime, endTime])
}
